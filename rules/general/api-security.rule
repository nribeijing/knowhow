## 🛡️ 输入验证

### Pydantic 验证

#### 基础验证

```python
from pydantic import BaseModel, EmailStr, Field, validator
import re

class UserCreate(BaseModel):
    """创建用户请求 - 完整验证"""
    
    # 邮箱验证
    email: EmailStr
    
    # 字符串长度验证
    name: str = Field(..., min_length=1, max_length=100)
    
    # 密码强度验证
    password: str = Field(..., min_length=8, max_length=128)
    
    # 正则验证
    phone: str = Field(..., regex=r'^\+?1?\d{9,15}$')
    
    @validator('password')
    def validate_password(cls, v):
        """密码强度验证"""
        if not any(c.isupper() for c in v):
            raise ValueError('密码必须包含大写字母')
        if not any(c.isdigit() for c in v):
            raise ValueError('密码必须包含数字')
        if not any(c in '!@#$%^&*(),.?":{}|<>' for c in v):
            raise ValueError('密码必须包含特殊字符')
        return v
```

#### 自定义验证

```python
class ReservationCreate(BaseModel):
    """创建预约请求"""
    
    museum_id: UUID
    hall_id: UUID
    
    # 日期验证
    visit_date: date = Field(..., description="参观日期")
    
    # 时间范围验证
    visit_time: int = Field(..., ge=10, le=18, description="参观时间 (10-18 点)")
    
    # 人数验证
    visitor_count: int = Field(..., gt=0, le=50, description="参观人数")
    
    @validator('visit_date')
    def validate_visit_date(cls, v):
        """参观日期必须是未来"""
        if v < date.today():
            raise ValueError('参观日期不能是过去')
        return v
    
    @validator('visit_time')
    def validate_visit_time(cls, v):
        """参观时间验证"""
        if v < 10 or v > 18:
            raise ValueError('参观时间必须在 10:00-18:00 之间')
        return v
```

