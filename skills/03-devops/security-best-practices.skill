## 🚨 安全监控

### 安全日志

```python
# 安全事件日志
import logging

security_logger = logging.getLogger('security')

def log_security_event(event_type: str, user_id: str, details: dict):
    security_logger.warning(
        f"Security event: {event_type}",
        extra={
            'event_type': event_type,
            'user_id': user_id,
            'details': details,
            'timestamp': datetime.utcnow().isoformat(),
            'ip_address': get_client_ip()
        }
    )

# 使用场景
log_security_event('LOGIN_FAILED', user_id, {'email': email})
log_security_event('UNAUTHORIZED_ACCESS', user_id, {'resource': resource})
log_security_event('PASSWORD_CHANGED', user_id, {})
```

### 入侵检测

```python
# 异常登录检测
class LoginAnomalyDetector:
    def __init__(self, redis_client):
        self.redis = redis_client
    
    def check_anomaly(self, user_id: str, ip_address: str, user_agent: str) -> bool:
        # 检查地理位置异常
        last_login = self.redis.get(f"user:{user_id}:last_login")
        if last_login:
            last_ip = self.redis.get(f"user:{user_id}:last_ip")
            if self._is_different_location(last_ip, ip_address):
                return True
        
        # 检查频率异常
        login_count = self.redis.get(f"user:{user_id}:login_count:1h")
        if login_count and int(login_count) > 10:
            return True
        
        return False
    
    def record_login(self, user_id: str, ip_address: str):
        self.redis.setex(f"user:{user_id}:last_login", 3600, datetime.utcnow().isoformat())
        self.redis.setex(f"user:{user_id}:last_ip", 3600, ip_address)
        self.redis.incr(f"user:{user_id}:login_count:1h")
        self.redis.expire(f"user:{user_id}:login_count:1h", 3600)
```

