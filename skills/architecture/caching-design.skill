## 🔥 缓存问题与解决方案

### 缓存穿透

```markdown
### 问题
- 查询不存在的数据
- 缓存未命中
- 请求直达数据库
- 数据库压力大

### 解决方案
1. 布隆过滤器
2. 缓存空值
3. 接口限流
```

```python
# 解决方案 1: 布隆过滤器
from redisbloom.client import Client

bf = Client()

def get_user(user_id):
    # 布隆过滤器检查
    if not bf.exists("users", user_id):
        return None
    
    # 正常查询
    user = cache.get(f"user:{user_id}")
    if not user:
        user = db.query(User).get(user_id)
        if user:
            cache.setex(f"user:{user_id}", 300, user)
        else:
            # 缓存空值
            cache.setex(f"user:{user_id}", 60, None)
        return user
    
    return user

# 解决方案 2: 缓存空值
def get_user(user_id):
    user = cache.get(f"user:{user_id}")
    if user is None:
        user = db.query(User).get(user_id)
        cache.setex(f"user:{user_id}", 60, user or {})  # 缓存空对象
        return user
    return user if user else None
```

### 缓存击穿

```markdown
### 问题
- 热点 key 过期
- 大量请求直达数据库
- 数据库瞬间压力大

### 解决方案
1. 互斥锁
2. 逻辑过期
3. 永不过期
```

```python
# 解决方案 1: 互斥锁
import threading

lock = threading.Lock()

def get_user(user_id):
    user = cache.get(f"user:{user_id}")
    if user:
        return user
    
    # 获取互斥锁
    if lock.acquire(timeout=1):
        try:
            # 双重检查
            user = cache.get(f"user:{user_id}")
            if user:
                return user
            
            user = db.query(User).get(user_id)
            cache.setex(f"user:{user_id}", 300, user)
            return user
        finally:
            lock.release()
    else:
        # 等待后重试
        time.sleep(0.1)
        return get_user(user_id)

# 解决方案 2: 逻辑过期
def get_user(user_id):
    user_data = cache.get(f"user:{user_id}")
    if not user_data:
        return db.query(User).get(user_id)
    
    # 检查逻辑过期时间
    if time.time() > user_data['expire_at']:
        # 异步更新缓存
        threading.Thread(target=update_cache, args=(user_id,)).start()
    
    return user_data['data']
```

### 缓存雪崩

```markdown
### 问题
- 大量 key 同时过期
- 请求直达数据库
- 数据库崩溃

### 解决方案
1. 随机过期时间
2. 热点数据永不过期
3. 多级缓存
```

```python
# 解决方案 1: 随机过期时间
import random

def cache_user(user_id, user_data):
    # 基础过期时间 5 分钟 + 随机 0-5 分钟
    expire_time = 300 + random.randint(0, 300)
    cache.setex(f"user:{user_id}", expire_time, user_data)

# 解决方案 2: 多级缓存
# L1: 本地缓存（Guava/Caffeine）
# L2: 分布式缓存（Redis）
# L3: 数据库

from cachetools import TTLCache

local_cache = TTLCache(maxsize=1000, ttl=60)

def get_user(user_id):
    # L1: 本地缓存
    user = local_cache.get(user_id)
    if user:
        return user
    
    # L2: 分布式缓存
    user = redis.get(f"user:{user_id}")
    if user:
        local_cache[user_id] = user
        return user
    
    # L3: 数据库
    user = db.query(User).get(user_id)
    if user:
        redis.setex(f"user:{user_id}", 300, user)
        local_cache[user_id] = user
    return user
```

