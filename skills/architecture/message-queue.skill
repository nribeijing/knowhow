## 📊 Kafka 最佳实践

### Topic 设计

```python
"""
Kafka Topic 设计原则
"""

# Topic 命名规范
# 格式：业务。子业务。事件类型
"user.order.created"
"user.payment.completed"
"inventory.stock.updated"

# Partition 数量设计
# 基于吞吐量：吞吐量 / 单 Partition 吞吐量
# 基于消费者：消费者数量
# 基于顺序：需要顺序的放同一 Partition

# 复制因子
# 生产环境：至少 3
# 关键业务：至少 5
```

### 生产者配置

```python
"""
Kafka 生产者优化配置
"""

from kafka import KafkaProducer

producer = KafkaProducer(
    bootstrap_servers=['localhost:9092'],
    
    # 可靠性配置
    acks='all',  # 所有副本确认
    retries=3,
    retry_backoff_ms=100,
    
    # 性能配置
    batch_size=16384,  # 16KB
    linger_ms=5,  # 等待 5ms 批量发送
    compression_type='gzip',  # 压缩
    
    # 幂等性
    enable_idempotence=True,
)

# 发送消息
future = producer.send('topic', key=b'key', value=b'value')

# 异步回调
future.add_callback(lambda metadata: print(f"Sent: {metadata.offset}"))
future.add_errback(lambda exception: print(f"Error: {exception}"))

# 等待发送完成
producer.flush()
```

### 消费者配置

```python
"""
Kafka 消费者优化配置
"""

from kafka import KafkaConsumer

consumer = KafkaConsumer(
    'topic',
    bootstrap_servers=['localhost:9092'],
    
    # 消费者组
    group_id='my-consumer-group',
    
    # 偏移量管理
    auto_offset_reset='earliest',  # 从最早开始
    enable_auto_commit=False,  # 手动提交
    
    # 性能配置
    max_poll_records=500,  # 每次拉取数量
    fetch_max_wait_ms=500,  # 等待时间
    session_timeout_ms=30000,  # 会话超时
    
    # 反序列化
    value_deserializer=lambda m: json.loads(m.decode('utf-8')),
)

# 消费消息
for message in consumer:
    try:
        # 处理消息
        process(message.value)
        # 手动提交偏移量
        consumer.commit()
    except Exception as e:
        # 处理失败
        log_error(e)
        # 可以选择重新消费
```

