### API 网关实现

```python
# Kong 配置
services:
  - name: user-service
    url: http://user-service:8000
    routes:
      - paths: [/api/v1/users]
        methods: [GET, POST, PUT, DELETE]
  
  - name: order-service
    url: http://order-service:8000
    routes:
      - paths: [/api/v1/orders]
        methods: [GET, POST, PUT, DELETE]

plugins:
  - name: jwt
    config:
      key_claim_name: sub
      secret: ${JWT_SECRET}
  
  - name: rate-limiting
    config:
      minute: 100
      policy: local
  
  - name: cors
    config:
      origins: [https://example.com]
```

### BFF 模式 (Backend for Frontend)

```python
# BFF for Web
class WebBFF:
    def __init__(self):
        self.user_service = UserServiceClient()
        self.order_service = OrderServiceClient()
        self.product_service = ProductServiceClient()
    
    async def get_user_dashboard(self, user_id: int) -> dict:
        # 聚合多个服务数据
        user, orders, products = await asyncio.gather(
            self.user_service.get_user(user_id),
            self.order_service.get_user_orders(user_id),
            self.product_service.get_recommendations(user_id)
        )
        
        return {
            "user": user,
            "recent_orders": orders[:5],
            "recommended_products": products[:10]
        }

# BFF for Mobile
class MobileBFF:
    def __init__(self):
        self.user_service = UserServiceClient()
        self.order_service = OrderServiceClient()
    
    async def get_mobile_home(self, user_id: int) -> dict:
        # 移动端简化数据
        user, orders = await asyncio.gather(
            self.user_service.get_user(user_id),
            self.order_service.get_user_orders(user_id, limit=3)
        )
        
        return {
            "user": {"name": user.name, "avatar": user.avatar},
            "recent_orders": orders
        }
```

