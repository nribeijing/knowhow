## 📦 代码复用

### DRY 原则

```python
# ❌ 重复代码
def create_user(email, name):
    if not email:
        raise ValueError("邮箱不能为空")
    if not is_valid_email(email):
        raise ValueError("邮箱格式不正确")
    ...

def update_user(user_id, email, name):
    if not email:
        raise ValueError("邮箱不能为空")
    if not is_valid_email(email):
        raise ValueError("邮箱格式不正确")
    ...

# ✅ 提取公共逻辑
def validate_email(email):
    if not email:
        raise ValueError("邮箱不能为空")
    if not is_valid_email(email):
        raise ValueError("邮箱格式不正确")

def create_user(email, name):
    validate_email(email)
    ...

def update_user(user_id, email, name):
    validate_email(email)
    ...
```

### 组合优于继承

```python
# ❌ 过度继承
class Animal:
    ...

class Mammal(Animal):
    ...

class Dog(Mammal):
    ...

class Cat(Mammal):
    ...

# ✅ 使用组合
class Animal:
    def __init__(self, sound_behavior, move_behavior):
        self.sound_behavior = sound_behavior
        self.move_behavior = move_behavior
    
    def make_sound(self):
        return self.sound_behavior.make_sound()
    
    def move(self):
        return self.move_behavior.move()

class BarkSound:
    def make_sound(self):
        return "Woof!"

class WalkMove:
    def move(self):
        return "Walking"

dog = Animal(BarkSound(), WalkMove())
```

