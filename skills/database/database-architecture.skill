## 🔒 数据安全

### 加密存储

```python
# SQLAlchemy 加密字段
from sqlalchemy_utils import EncryptedType

class User(Base):
    __tablename__ = "users"
    
    id = Column(Integer, primary_key=True)
    email = Column(String)
    ssn = Column(EncryptedType(String, settings.ENCRYPTION_KEY))  # 加密
    credit_card = Column(EncryptedType(String, settings.ENCRYPTION_KEY))  # 加密
```

### 数据脱敏

```python
# 数据脱敏
def mask_email(email):
    name, domain = email.split('@')
    masked_name = name[0] + '*' * (len(name) - 2) + name[-1]
    return f"{masked_name}@{domain}"

def mask_phone(phone):
    return phone[:3] + '****' + phone[-4:]

# 使用
user_data = {
    "email": mask_email(user.email),
    "phone": mask_phone(user.phone)
}
```

### 备份恢复

```python
# 数据库备份
import subprocess
from datetime import datetime

class DatabaseBackup:
    def __init__(self, db_url, backup_dir):
        self.db_url = db_url
        self.backup_dir = backup_dir
    
    def backup(self):
        timestamp = datetime.utcnow().strftime('%Y%m%d_%H%M%S')
        backup_file = f"{self.backup_dir}/backup_{timestamp}.sql"
        
        subprocess.run([
            'pg_dump',
            self.db_url,
            '-f', backup_file
        ], check=True)
        
        return backup_file
    
    def restore(self, backup_file):
        subprocess.run([
            'psql',
            self.db_url,
            '-f', backup_file
        ], check=True)
```

