## 📦 Pinia 调试

### Store 状态调试

**状态检查**:
```typescript
// stores/user.ts
import { defineStore } from 'pinia'
import { ref, computed } from 'vue'

export const useUserStore = defineStore('user', () => {
  // State
  const currentUser = ref<User | null>(null)
  const users = ref<User[]>([])

  // Getters
  const isLoggedIn = computed(() => !!currentUser.value)
  const activeUsers = computed(() => users.value.filter(u => u.isActive))

  // Actions
  const fetchUser = async (id: number) => {
    console.log('fetchUser 调用:', { id })
    try {
      const response = await api.getUser(id)
      currentUser.value = response.data
      console.log('fetchUser 成功:', currentUser.value)
    } catch (error) {
      console.error('fetchUser 失败:', error)
      throw error
    }
  }

  const deleteUser = async (id: number) => {
    console.log('deleteUser 调用:', { id })
    await api.deleteUser(id)
    users.value = users.value.filter(u => u.id !== id)
    console.log('deleteUser 完成')
  }

  return {
    currentUser,
    users,
    isLoggedIn,
    activeUsers,
    fetchUser,
    deleteUser
  }
})
```

**调试 DevTools**:
```typescript
// 启用 Pinia DevTools 插件
import { createPinia } from 'pinia'
import { createLogger } from 'pinia'

const pinia = createPinia()

// 开发环境启用日志
if (import.meta.env.DEV) {
  pinia.use(createLogger({
    logger: console.log,
    expandActionLog: true
  }))
}
```

---

### Actions 调试

**Action 调用追踪**:
```typescript
// stores/user.ts
export const useUserStore = defineStore('user', () => {
  const fetchUser = async (id: number) => {
    const actionId = `fetchUser_${id}_${Date.now()}`
    
    console.group(`Action: ${actionId}`)
    console.log('开始执行 fetchUser', { id })
    
    try {
      const startTime = Date.now()
      const response = await api.getUser(id)
      const endTime = Date.now()
      
      console.log('API 调用完成:', {
        duration: endTime - startTime,
        data: response.data
      })
      
      currentUser.value = response.data
      console.log('State 更新完成')
      
      console.groupEnd()
      return response.data
    } catch (error) {
      console.error('Action 失败:', error)
      console.groupEnd()
      throw error
    }
  }

  return { fetchUser }
})
```

