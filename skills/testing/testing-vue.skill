## 📏 集成测试

### 多组件测试

**测试组件交互**:
```typescript
describe('UserList Integration', () => {
  it('renders multiple UserCard components', () => {
    const users = [
      { id: 1, name: 'John' },
      { id: 2, name: 'Jane' }
    ]
    
    const wrapper = mount(UserList, {
      props: {
        users
      }
    })
    
    expect(wrapper.findAllComponents(UserCard)).toHaveLength(2)
  })
  
  it('emits event when child component emits', async () => {
    const wrapper = mount(UserList, {
      props: {
        users: [{ id: 1, name: 'John' }]
      }
    })
    
    const userCard = wrapper.findComponent(UserCard)
    await userCard.vm.$emit('delete', 1)
    
    expect(wrapper.emitted('user-deleted')).toBeTruthy()
  })
})
```

---

### API Mock

**MSW Mock**:
```typescript
import { setupServer } from 'msw/node'
import { rest } from 'msw'

const server = setupServer(
  rest.get('/api/v1/users/:id', (req, res, ctx) => {
    return res(
      ctx.json({
        id: req.params.id,
        name: 'John Doe',
        email: 'john@example.com'
      })
    )
  })
)

beforeAll(() => server.listen())
afterEach(() => server.resetHandlers())
afterAll(() => server.close())

describe('UserCard with API', () => {
  it('fetches user data on mount', async () => {
    const wrapper = mount(UserCard, {
      props: {
        id: 1
      }
    })
    
    // 等待数据加载
    await wrapper.vm.$nextTick()
    await waitFor(() => {
      expect(wrapper.text()).toContain('John Doe')
    })
  })
})
```

