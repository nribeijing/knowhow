## 📏 组件测试

### Vitest 配置

**vite.config.ts**:
```typescript
import { defineConfig } from 'vite'
import vue from '@vitejs/plugin-vue'

export default defineConfig({
  plugins: [vue()],
  test: {
    globals: true,
    environment: 'jsdom',
    setupFiles: ['./src/test/setup.ts'],
    coverage: {
      provider: 'v8',
      reporter: ['text', 'json', 'html'],
      threshold: {
        lines: 80,
        functions: 80,
        branches: 70,
        statements: 80
      }
    }
  }
})
```

---

### 组件渲染测试

**基础测试**:
```typescript
import { mount } from '@vue/test-utils'
import { describe, it, expect } from 'vitest'
import UserCard from '@/components/UserCard.vue'

describe('UserCard', () => {
  it('renders component with props', () => {
    const wrapper = mount(UserCard, {
      props: {
        name: 'John Doe',
        email: 'john@example.com'
      }
    })
    
    expect(wrapper.text()).toContain('John Doe')
    expect(wrapper.text()).toContain('john@example.com')
  })
  
  it('renders default slot content', () => {
    const wrapper = mount(UserCard, {
      slots: {
        default: '<p>Custom content</p>'
      }
    })
    
    expect(wrapper.text()).toContain('Custom content')
  })
})
```

---

### Props 测试

**Props 验证**:
```typescript
describe('UserCard Props', () => {
  it('accepts valid props', () => {
    const wrapper = mount(UserCard, {
      props: {
        name: 'John',
        email: 'john@example.com',
        isActive: true
      }
    })
    
    expect(wrapper.props().name).toBe('John')
    expect(wrapper.props().email).toBe('john@example.com')
  })
  
  it('uses default props', () => {
    const wrapper = mount(UserCard, {
      props: {
        name: 'John'
      }
    })
    
    expect(wrapper.props().isActive).toBe(false) // 默认值
  })
  
  it('validates required props', () => {
    expect(() => {
      mount(UserCard) // 缺少必需 props
    }).toThrow()
  })
})
```

---

### Events 测试

**事件触发**:
```typescript
describe('UserCard Events', () => {
  it('emits click event', async () => {
    const wrapper = mount(UserCard, {
      props: {
        name: 'John'
      }
    })
    
    await wrapper.trigger('click')
    
    expect(wrapper.emitted('click')).toBeTruthy()
    expect(wrapper.emitted('click')).toHaveLength(1)
  })
  
  it('emits delete event with payload', async () => {
    const wrapper = mount(UserCard, {
      props: {
        id: 1,
        name: 'John'
      }
    })
    
    await wrapper.find('.delete-btn').trigger('click')
    
    expect(wrapper.emitted('delete')).toBeTruthy()
    expect(wrapper.emitted('delete')[0]).toEqual([1])
  })
  
  it('emits update event on input', async () => {
    const wrapper = mount(UserCard, {
      props: {
        name: 'John'
      }
    })
    
    const input = wrapper.find('input')
    await input.setValue('Jane')
    
    expect(wrapper.emitted('update:name')).toBeTruthy()
    expect(wrapper.emitted('update:name')[0]).toEqual(['Jane'])
  })
})
```

---

### 用户交互测试

**模拟用户操作**:
```typescript
describe('UserCard Interactions', () => {
  it('toggles active state on button click', async () => {
    const wrapper = mount(UserCard, {
      props: {
        id: 1,
        name: 'John',
        isActive: false
      }
    })
    
    // 初始状态
    expect(wrapper.classes()).not.toContain('active')
    
    // 点击切换
    await wrapper.find('.toggle-btn').trigger('click')
    
    // 验证状态变化
    expect(wrapper.classes()).toContain('active')
    expect(wrapper.emitted('toggle')).toBeTruthy()
  })
  
  it('submits form on submit', async () => {
    const wrapper = mount(UserForm, {
      props: {
        initialData: {
          name: 'John',
          email: 'john@example.com'
        }
      }
    })
    
    // 填写表单
    await wrapper.find('input[name="name"]').setValue('Jane')
    await wrapper.find('input[name="email"]').setValue('jane@example.com')
    
    // 提交表单
    await wrapper.find('form').trigger('submit.prevent')
    
    // 验证提交
    expect(wrapper.emitted('submit')).toBeTruthy()
    expect(wrapper.emitted('submit')[0][0]).toEqual({
      name: 'Jane',
      email: 'jane@example.com'
    })
  })
})
```

---

### Pinia Store 测试

**Mock Store**:
```typescript
import { createPinia, setActivePinia } from 'pinia'
import { useUserStore } from '@/stores/user'

describe('UserCard with Pinia', () => {
  let pinia: ReturnType<typeof createPinia>
  
  beforeEach(() => {
    pinia = createPinia()
    setActivePinia(pinia)
  })
  
  it('uses user store', async () => {
    const userStore = useUserStore()
    userStore.currentUser = { id: 1, name: 'John' }
    
    const wrapper = mount(UserCard, {
      global: {
        plugins: [pinia]
      }
    })
    
    expect(wrapper.text()).toContain('John')
  })
  
  it('dispatches store actions', async () => {
    const wrapper = mount(UserCard, {
      global: {
        plugins: [pinia]
      },
      props: {
        id: 1
      }
    })
    
    const userStore = useUserStore()
    userStore.deleteUser = vi.fn()
    
    await wrapper.find('.delete-btn').trigger('click')
    
    expect(userStore.deleteUser).toHaveBeenCalledWith(1)
  })
})
```

---

### Router 测试

**Mock Router**:
```typescript
import { createRouter, createWebHistory } from 'vue-router'
import { routes } from '@/router'

describe('UserCard with Router', () => {
  const router = createRouter({
    history: createWebHistory(),
    routes
  })
  
  it('navigates on click', async () => {
    const wrapper = mount(UserCard, {
      global: {
        plugins: [router]
      },
      props: {
        id: 1
      }
    })
    
    await router.push('/')
    await wrapper.find('.view-profile').trigger('click')
    
    expect(router.currentRoute.value.path).toBe('/users/1')
  })
})
```

