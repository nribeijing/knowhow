## 🔧 测试工具

### 测试辅助函数

**辅助函数**:
```typescript
// src/test/helpers.ts
import { mount, VueWrapper } from '@vue/test-utils'
import { createPinia } from 'pinia'
import { createRouter, createWebHistory } from 'vue-router'

export function mountWithPlugins(component: any, options: any = {}) {
  const pinia = createPinia()
  const router = createRouter({
    history: createWebHistory(),
    routes: []
  })
  
  return mount(component, {
    global: {
      plugins: [pinia, router],
      ...options.global
    },
    ...options
  })
}

export function createMockUser(overrides: any = {}) {
  return {
    id: 1,
    email: 'test@example.com',
    name: 'Test User',
    ...overrides
  }
}
```

---

### 自定义 Matchers

**Vitest Matchers**:
```typescript
// src/test/setup.ts
import { expect } from 'vitest'

expect.extend({
  toBeVisible(wrapper: VueWrapper) {
    const isVisible = wrapper.element.isVisible()
    return {
      pass: isVisible,
      message: () => `expected wrapper ${isVisible ? 'not ' : ''}to be visible`
    }
  },
  
  toHaveEmitted(wrapper: VueWrapper, event: string) {
    const emitted = wrapper.emitted(event)
    return {
      pass: !!emitted,
      message: () => `expected wrapper ${emitted ? 'not ' : ''}to have emitted ${event}`
    }
  }
})
```

